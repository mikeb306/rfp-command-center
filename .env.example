PORT=4310
STORAGE_BACKEND=json
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rfp_app

# Security
AUTH_MODE=off
# Format: token:role,token2:role  where role in viewer|editor|reviewer|admin
AUTH_TOKENS=devtoken:admin
RATE_LIMIT_MODE=off
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=120

# Connectors
CONNECTOR_SCHEDULER=on
CONNECTOR_POLL_MINUTES=1440

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
