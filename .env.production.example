# Core runtime
NODE_ENV=production
PORT=4310
STORAGE_BACKEND=postgres
DATABASE_URL=postgres://rfp_app_user:REPLACE_ME@db-host:5432/rfp_app

# Security (REQUIRED in production)
AUTH_MODE=on
# Format token:role,token2:role. Use long random secrets.
AUTH_TOKENS=REPLACE_ADMIN_TOKEN:admin,REPLACE_REVIEWER_TOKEN:reviewer,REPLACE_EDITOR_TOKEN:editor,REPLACE_VIEWER_TOKEN:viewer
RATE_LIMIT_MODE=on
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=180

# Connector scheduler (start off, then enable after validation)
CONNECTOR_SCHEDULER=off
CONNECTOR_POLL_MINUTES=1440

# OpenAI (optional but recommended)
OPENAI_API_KEY=REPLACE_OPENAI_KEY
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional operational toggles
# AUTH_MODE=off only for local development
# RATE_LIMIT_MODE=off only for local testing
